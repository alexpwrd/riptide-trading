# Kraken API (for live market data)
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret

# PRISM API (optional, for multi-asset resolution)
PRISM_API_KEY=your_prism_api_key

# ─── ERC-8004 Challenge (Sepolia Testnet, Chain ID: 11155111) ───
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_CHAIN_ID=11155111

# Operator wallet (owns ERC-721 agent identity, pays gas)
OPERATOR_ADDRESS=0xYourOperatorAddress
OPERATOR_PRIVATE_KEY=your_operator_private_key

# Agent wallet (signs EIP-712 trade intents)
AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress
AGENT_WALLET_PRIVATE_KEY=your_agent_wallet_private_key

# Shared hackathon contracts (Sepolia)
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1

# Agent ID (set after registration)
AGENT_ID=

# Discord webhook (optional)
CLAWDTRADER_DISCORD_WEBHOOK=
